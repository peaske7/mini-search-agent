# Copy to .env and fill in your values
# Then: export $(cat .env | xargs)

# Required — your Minimax API key (used for both LLM calls and web search)
MINIMAX_API_KEY=your_key_here

# Optional overrides
MINIMAX_API_HOST=https://api.minimax.chat   # or https://api.minimax.io for China endpoint
AGENT_MODEL=MiniMax-Text-01
AGENT_MAX_STEPS=12
